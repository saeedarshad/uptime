// UptimeHQ data model.
// Conventions: all money in integer cents; all timestamps stored UTC.
// Multi-tenant: every tenant-owned row carries orgId and must be queried
// through the org-scoped helper in src/lib/tenant.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BusinessType {
  auto
  machine_shop
  gym
  contractor
  restaurant
  other
}

enum Plan {
  trial
  active
  cancelled
}

enum UserRole {
  owner
  admin
  tech
}

enum AssetStatus {
  running
  down
  retired
}

enum WorkOrderStatus {
  open
  in_progress
  done
  cancelled
}

enum Priority {
  low
  normal
  high
}

enum PmTriggerType {
  time
  meter
}

enum PmTaskStatus {
  upcoming
  due
  overdue
  done
  skipped
}

enum DocumentKind {
  manual
  certificate
  inspection
  other
}

enum InsightSeverity {
  info
  warn
  critical
}

enum InsightAction {
  create_wo
  view_schedule
  export_pdf
  none
}

enum BillingInterval {
  monthly
  annual
}

model Organization {
  id             String       @id @default(cuid())
  name           String
  slug           String       @unique
  businessType   BusinessType @default(other)
  city           String?
  timezone       String       @default("America/Chicago")
  laborRateCents Int          @default(7500)
  pinCode        String? // 4 digits, nullable
  plan           Plan         @default(trial)
  trialEndsAt    DateTime?
  // Denormalized paid-through date = max(periodEnd) over non-voided payments.
  // Access is computed from trialEndsAt/currentPeriodEndsAt, not `plan` alone.
  currentPeriodEndsAt DateTime?
  // Configurable symptom chips shown on the public report flow.
  symptomChips   String[]     @default([])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  users          User[]
  assets         Asset[]
  workOrders     WorkOrder[]
  pmSchedules    PMSchedule[]
  pmTasks        PMTask[]
  insights       Insight[]
  activityLogs   ActivityLog[]
  invites        Invite[]
  subscriptionPayments SubscriptionPayment[]
}

model User {
  id           String   @id @default(cuid())
  orgId        String
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(tech)
  // Platform operator flag — grants access to the /admin subscriptions console.
  // Bootstrapped for admin@uptimehq.app via migration; toggled only in DB.
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sessions        Session[]
  assignedWOs     WorkOrder[]  @relation("AssignedTo")

  @@index([orgId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  // Random opaque token stored in the session cookie (hashed at rest).
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Invite {
  id        String   @id @default(cuid())
  orgId     String
  email     String
  name      String
  role      UserRole @default(tech)
  token     String   @unique
  acceptedAt DateTime?
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model Asset {
  id                  String      @id @default(cuid())
  orgId               String
  publicId            String      @unique // unguessable 10-char slug for QR URLs
  name                String
  category            String?
  location            String?
  status              AssetStatus @default(running)
  purchaseCostCents   Int?
  purchaseDate        DateTime?
  photoUrl            String?
  notes               String?
  isComplianceTracked Boolean     @default(false)
  archived            Boolean     @default(false)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  org           Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  workOrders    WorkOrder[]
  pmSchedules   PMSchedule[]
  meterReadings MeterReading[]
  documents     AssetDocument[]

  @@index([orgId])
}

model WorkOrder {
  id               String          @id @default(cuid())
  orgId            String
  assetId          String
  number           Int // per-org sequential (rendered WO-118)
  title            String
  description      String?
  symptom          String?
  status           WorkOrderStatus @default(open)
  priority         Priority        @default(normal)
  reportedByName   String
  assignedToUserId String?
  partsCostCents   Int             @default(0)
  laborHours       Decimal         @default(0) @db.Decimal(8, 2)
  laborCostCents   Int             @default(0)
  downtimeHours    Decimal         @default(0) @db.Decimal(8, 2)
  openedAt         DateTime        @default(now())
  closedAt         DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  org        Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  asset      Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assignedTo User?           @relation("AssignedTo", fields: [assignedToUserId], references: [id])
  photos     WorkOrderPhoto[]

  @@unique([orgId, number])
  @@index([orgId])
  @@index([assetId])
}

model WorkOrderPhoto {
  id          String    @id @default(cuid())
  workOrderId String
  url         String
  createdAt   DateTime  @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
}

model PMSchedule {
  id                String        @id @default(cuid())
  orgId             String
  assetId           String
  taskName          String
  instructions      String?
  triggerType       PmTriggerType @default(time)
  intervalDays      Int? // when triggerType = time
  meterIntervalUnits Int? // when triggerType = meter
  meterUnitLabel    String? // e.g. "hours", "miles"
  lastCompletedAt   DateTime?
  lastCompletedMeter Decimal?     @db.Decimal(12, 2)
  active            Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  asset   Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  pmTasks PMTask[]

  @@index([orgId])
  @@index([assetId])
}

model PMTask {
  id              String       @id @default(cuid())
  orgId           String
  scheduleId      String
  dueAt           DateTime?
  dueMeter        Decimal?     @db.Decimal(12, 2)
  status          PmTaskStatus @default(upcoming)
  completedAt     DateTime?
  completedByName String?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  schedule PMSchedule   @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([scheduleId])
}

model MeterReading {
  id            String   @id @default(cuid())
  assetId       String
  value         Decimal  @db.Decimal(12, 2)
  unitLabel     String
  readAt        DateTime @default(now())
  enteredByName String
  createdAt     DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
}

model AssetDocument {
  id        String       @id @default(cuid())
  assetId   String
  title     String
  fileUrl   String
  kind      DocumentKind @default(other)
  expiresAt DateTime?
  createdAt DateTime     @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
}

model Insight {
  id         String          @id @default(cuid())
  orgId      String
  ruleKey    String
  assetId    String?
  severity   InsightSeverity @default(info)
  title      String
  body       String
  actionType InsightAction   @default(none)
  dedupeKey  String
  dismissedAt DateTime?
  computedAt DateTime        @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, dedupeKey])
  @@index([orgId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  orgId     String
  actorName String
  verb      String
  subject   String
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

// A manually-recorded off-platform payment covering a subscription period.
// Money in integer cents; periods stored UTC. Entered by the operator from the
// admin panel — the platform does not process payments itself.
model SubscriptionPayment {
  id                  String          @id @default(cuid())
  orgId               String
  interval            BillingInterval @default(monthly)
  amountCents         Int
  periodStart         DateTime
  periodEnd           DateTime
  paidAt              DateTime        @default(now())
  method              String? // "Bank transfer", "Stripe (manual)", etc.
  reference           String? // invoice / txn note
  note                String?
  voided              Boolean         @default(false)
  createdByAdminEmail String?
  createdAt           DateTime        @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}


# --- Required ---
# Postgres connection string.
DATABASE_URL="postgresql://user:pass@host:5432/uptime?schema=public"
# Public base URL of the app (used to build QR code links). No trailing slash.
APP_URL="http://localhost:3000"
# Secret used to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET="change-me"
# Shared secret guarding POST /api/jobs/run. Generate with: openssl rand -hex 32
CRON_SECRET="change-me"

# --- Platform admin (the /admin subscriptions console) ---
# The admin is a normal User with isAdmin=true; it is bootstrapped on deploy via
# migration (admin@uptimehq.app / admin9898) and can change its password in the
# admin panel. These vars only override the defaults used by `npm run seed:admin`.
# ADMIN_EMAIL="admin@uptimehq.app"
# ADMIN_PASSWORD="admin9898"
# ADMIN_NAME="Platform Admin"

# --- File storage ---
# Where uploaded photos/documents are written when STORAGE_DRIVER=local.
UPLOAD_DIR="/data/uploads"
# "local" (disk) or "s3" (stubbed for later).
STORAGE_DRIVER="local"
# S3 driver config (only used when STORAGE_DRIVER=s3):
# S3_BUCKET=""
# S3_REGION=""
# S3_ENDPOINT=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""

# --- Email (optional; emails no-op when SMTP_HOST is unset) ---
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="UptimeHQ <no-reply@uptimehq.app>"
